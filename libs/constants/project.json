{
  "name": "constants",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/constants/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/constants/tsconfig.lib.json",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/constants/tsconfig.lib.json --noEmit",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tags": ["scope:shared", "type:lib"]
}
